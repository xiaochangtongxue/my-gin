{
    "swagger": "2.0",
    "info": {
        "description": "生产级 Gin 框架脚手架 API",
        "title": "My-Gin API",
        "termsOfService": "http://swagger.io/terms/",
        "contact": {
            "name": "API Support",
            "url": "http://www.example.com/support",
            "email": "support@example.com"
        },
        "license": {
            "name": "Apache 2.0",
            "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
        },
        "version": "1.0"
    },
    "host": "localhost:8080",
    "paths": {
        "/api/v1/logout": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "删除 Refresh Token 并将 Access Token 加入黑名单",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "认证"
                ],
                "summary": "用户登出",
                "parameters": [
                    {
                        "description": "登出请求",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/github_com_xiaochangtongxue_my-gin_internal_dto_req.RefreshTokenReq"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/github_com_xiaochangtongxue_my-gin_pkg_response.Response"
                        }
                    }
                }
            }
        },
        "/api/v1/logout/all": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "删除用户的所有 Refresh Token 并将当前 Access Token 加入黑名单",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "认证"
                ],
                "summary": "登出所有设备",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/github_com_xiaochangtongxue_my-gin_pkg_response.Response"
                        }
                    }
                }
            }
        },
        "/api/v1/refresh": {
            "post": {
                "description": "使用 Refresh Token 获取新的 Access Token",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "认证"
                ],
                "summary": "刷新 Access Token",
                "parameters": [
                    {
                        "description": "刷新请求",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/github_com_xiaochangtongxue_my-gin_internal_dto_req.RefreshTokenReq"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/github_com_xiaochangtongxue_my-gin_pkg_response.Response"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/github_com_xiaochangtongxue_my-gin_internal_service.TokenPair"
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/github_com_xiaochangtongxue_my-gin_pkg_response.Response"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/github_com_xiaochangtongxue_my-gin_pkg_response.Response"
                        }
                    }
                }
            }
        },
        "/health": {
            "get": {
                "description": "检查服务运行状态（仅返回基本状态）",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "健康"
                ],
                "summary": "健康检查",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/github_com_xiaochangtongxue_my-gin_internal_dto_resp.CheckResponse"
                        }
                    }
                }
            }
        },
        "/health/live": {
            "get": {
                "description": "检查服务是否存活（轻量级，不检查依赖）",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "健康"
                ],
                "summary": "存活检查",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/github_com_xiaochangtongxue_my-gin_internal_dto_resp.CheckResponse"
                        }
                    },
                    "503": {
                        "description": "Service Unavailable",
                        "schema": {
                            "$ref": "#/definitions/github_com_xiaochangtongxue_my-gin_internal_dto_resp.CheckResponse"
                        }
                    }
                }
            }
        },
        "/health/ready": {
            "get": {
                "description": "检查服务及其依赖（数据库、Redis）的就绪状态",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "健康"
                ],
                "summary": "就绪检查",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/github_com_xiaochangtongxue_my-gin_internal_dto_resp.ReadyResponse"
                        }
                    },
                    "503": {
                        "description": "Service Unavailable",
                        "schema": {
                            "$ref": "#/definitions/github_com_xiaochangtongxue_my-gin_internal_dto_resp.ReadyResponse"
                        }
                    }
                }
            }
        },
        "/swagger/index.html": {
            "get": {
                "description": "访问 Swagger API 文档界面",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "文档"
                ],
                "summary": "Swagger API 文档",
                "responses": {}
            }
        }
    },
    "definitions": {
        "github_com_xiaochangtongxue_my-gin_internal_dto_req.RefreshTokenReq": {
            "type": "object",
            "required": [
                "refresh_token"
            ],
            "properties": {
                "refresh_token": {
                    "description": "Refresh Token",
                    "type": "string"
                }
            }
        },
        "github_com_xiaochangtongxue_my-gin_internal_dto_resp.Check": {
            "description": "组件健康状态",
            "type": "object",
            "properties": {
                "error": {
                    "description": "错误信息",
                    "type": "string"
                },
                "latency": {
                    "description": "响应耗时（毫秒）",
                    "type": "integer",
                    "example": 5
                },
                "status": {
                    "description": "up, down, degraded",
                    "type": "string",
                    "example": "up"
                }
            }
        },
        "github_com_xiaochangtongxue_my-gin_internal_dto_resp.CheckResponse": {
            "description": "简化版健康检查响应",
            "type": "object",
            "properties": {
                "status": {
                    "type": "string",
                    "example": "ok"
                },
                "time": {
                    "type": "string",
                    "example": "2025-01-02T15:04:05Z07:00"
                }
            }
        },
        "github_com_xiaochangtongxue_my-gin_internal_dto_resp.ReadyResponse": {
            "description": "完整版健康检查响应（包含各组件状态）",
            "type": "object",
            "properties": {
                "checks": {
                    "type": "object",
                    "additionalProperties": {
                        "$ref": "#/definitions/github_com_xiaochangtongxue_my-gin_internal_dto_resp.Check"
                    }
                },
                "status": {
                    "type": "string",
                    "example": "healthy"
                },
                "timestamp": {
                    "type": "string",
                    "example": "2025-01-02T15:04:05Z07:00"
                },
                "version": {
                    "type": "string",
                    "example": "1.0.0"
                }
            }
        },
        "github_com_xiaochangtongxue_my-gin_internal_service.TokenPair": {
            "description": "双 Token 响应（Access Token + Refresh Token）",
            "type": "object",
            "properties": {
                "access_token": {
                    "description": "Access Token",
                    "type": "string",
                    "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                },
                "expires_in": {
                    "description": "Access Token 过期时间（秒）",
                    "type": "integer",
                    "example": 1800
                },
                "refresh_token": {
                    "description": "Refresh Token",
                    "type": "string",
                    "example": "a1b2c3d4e5f6..."
                }
            }
        },
        "github_com_xiaochangtongxue_my-gin_pkg_response.Response": {
            "description": "统一 API 响应格式",
            "type": "object",
            "properties": {
                "code": {
                    "description": "业务状态码",
                    "type": "integer",
                    "example": 0
                },
                "data": {
                    "description": "响应数据"
                },
                "message": {
                    "description": "响应消息",
                    "type": "string",
                    "example": "success"
                },
                "request_id": {
                    "description": "请求ID",
                    "type": "string",
                    "example": "abc123"
                },
                "timestamp": {
                    "description": "时间戳",
                    "type": "integer",
                    "example": 1704067200
                }
            }
        }
    },
    "securityDefinitions": {
        "BearerAuth": {
            "description": "Type \"Bearer\" followed by a space and JWT token.",
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}