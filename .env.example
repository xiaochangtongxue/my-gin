# 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# 注意：.env 文件已被 .gitignore 排除，不会被提交到代码仓库

# ========================================
# 应用配置
# ========================================
APP_ENV=dev                                    # 运行环境: dev, test, prod
APP_SERVER_MODE=debug                          # 运行模式: debug, release, test
APP_SERVER_HOST=0.0.0.0                        # 监听地址
APP_SERVER_PORT=8080                           # 应用端口

# ========================================
# JWT 密钥配置（必填，至少32位）
# ========================================
# 生成方法: openssl rand -base64 32
APP_JWT_SECRET=your-jwt-secret-key-at-least-32-characters

# ========================================
# 数据库配置
# ========================================
APP_DATABASE_HOST=127.0.0.1                    # 数据库主机（docker-compose-full.yml 用 mysql）
APP_DATABASE_PORT=3306                          # 数据库端口
APP_DATABASE_USERNAME=root                      # 数据库用户名
APP_DATABASE_PASSWORD=your-database-password    # 数据库密码（必填）
APP_DATABASE_NAME=my_app_db                     # 数据库名称

# ========================================
# Redis 配置
# ========================================
APP_REDIS_HOST=127.0.0.1                        # Redis 主机（docker-compose-full.yml 用 redis）
APP_REDIS_PORT=6379                             # Redis 端口
APP_REDIS_PASSWORD=                             # Redis 密码（可选，无密码留空）
APP_REDIS_DB=0                                  # Redis DB

# ========================================
# Docker Compose 完整版专用（使用 docker-compose-full.yml 时填写）
# ========================================
# MYSQL_ROOT_PASSWORD=123456                    # MySQL root 密码
# MYSQL_DATABASE=my_app_db                      # MySQL 数据库名
# MYSQL_USERNAME=app_user                       # MySQL 应用用户
# MYSQL_PASSWORD=app_password                   # MySQL 应用密码
# MYSQL_PORT=3306                               # MySQL 对外端口
# REDIS_PORT=6379                               # Redis 对外端口
